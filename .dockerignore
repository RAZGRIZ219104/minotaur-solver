# Screening builds with `docker build --no-cache --network=none` (validator side:
# screening.py:_solver_build_command). --no-cache => every file in the build
# context is re-COPY'd on every submission, so trimming the context is the one
# build-time lever we own. Everything excluded here is either offline-only or a
# stale-bytecode hazard; nothing referenced by runtime *.py is dropped.

# Stale compiled bytecode — copying cpython-313 .pyc into a base image whose
# python may differ risks import-time surprises; the source is always copied too.
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Local envs / secrets — must never enter the image (also anti-leak).
.venv/
.env
.git/
*.log

# Offline-only trees: not imported by the solver at runtime.
tests/
# draft/ dropped (v421): only _generate_yield_plan uses it (yield intents),
# never hit by the swap benchmark — vector champion ships without it.
draft/


# NOTE: do NOT dockerignore mc_data.py or overrides.json — both ARE referenced by
# the runtime engine (_apex_champ_entry.py: `from mc_data import ...` and
# `_viking_override()` reads overrides.json). Excluding them drops them from the
# `docker build --no-cache` context -> ModuleNotFoundError at Stage 2 (the v395/v396
# rejection root cause, 2026-07-16). Only add a file here after grep-verifying it is
# imported/opened by ZERO runtime *.py.
